GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your-password
GARMIN_TOKEN_STORE=~/.garminconnect
GARMIN_CACHE_FOLDER=./tmp
GARMIN_CACHE_EXPIRATION_SECONDS=3600
API_KEY=replace-with-a-strong-random-value

# API Configuration (optional)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_RELOAD=false

# OpenAPI servers (comma-separated URLs shown in /openapi.json)
# OPENAPI_SERVERS=https://api.example.com,http://localhost:8000
